# Supabase (server - sensitive)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service_role_key_here

# Supabase (client - safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=anon_public_key_here

# Session / cookie settings (optional)
# Cookie name used by the server (default: pos_session)
SESSION_COOKIE_NAME=pos_session
# Session TTL in seconds (defaults to 3600)
SESSION_TTL_SECONDS=3600
# Remember-me TTL in seconds (defaults to 3600*24)
SESSION_TTL_REMEMBER_SECONDS=86400

# Runtime
NODE_ENV=development